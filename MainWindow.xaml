<Window x:Class="ClipNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNest"
        Height="760"
        Width="1280"
        MinHeight="640"
        MinWidth="980"
        Icon="Assets/clipnest.png"
        WindowStartupLocation="CenterScreen"
        Background="#F4F8FF">
    <Window.Resources>
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1D2433"/>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="78"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#667085"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DFE7F2"/>
        </Style>

        <Style x:Key="PrimaryIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="#2F7DF6"/>
            <Setter Property="BorderBrush" Value="#2F7DF6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>

        <Style x:Key="TagPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="#EAF3FF"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="238"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F2F7FF" Padding="22,24">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <Border Width="38" Height="38" CornerRadius="10" Background="#2F7DF6" Margin="0,0,12,0">
                            <Image Source="Assets/clipnest.png" Width="22" Height="22"/>
                        </Border>
                        <TextBlock Text="ClipNest" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#101828"/>
                    </StackPanel>

                    <Button x:Name="HistoryButton" Style="{StaticResource SidebarNavButtonStyle}" Click="HistoryButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE81C;" FontSize="18" VerticalAlignment="Center" Foreground="#2F7DF6"/>
                            <TextBlock Grid.Column="1" Text="历史" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="FavoritesButton" Style="{StaticResource SidebarNavButtonStyle}" Click="FavoritesButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE734;" FontSize="18" VerticalAlignment="Center" Foreground="#667085"/>
                            <TextBlock Grid.Column="1" Text="收藏" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButtonStyle}" Click="SettingsButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="18" VerticalAlignment="Center" Foreground="#667085"/>
                            <TextBlock Grid.Column="1" Text="设置" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Border Height="1" Background="#DFE8F5" Margin="0,18,0,16"/>
                    <TextBlock Text="管理" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,0,0,12"/>

                    <Button x:Name="PauseButton" Style="{StaticResource SidebarNavButtonStyle}" Click="PauseButton_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="14" BorderBrush="#E4ECF7" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#EAF3FF">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" Foreground="#2F7DF6" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="SummaryTitleText" Text="记录 0 / 100" FontSize="14" FontWeight="SemiBold" Foreground="#1D2433"/>
                                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                                <ProgressBar x:Name="HistoryUsageBar" Height="5" Minimum="0" Maximum="100" Value="0" Foreground="#2F7DF6" Background="#E5EDF8" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="10,22,10,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE708;" Foreground="#667085" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" Text="&#xE897;" Foreground="#667085" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" FontFamily="Segoe MDL2 Assets" Text="&#xE946;" Foreground="#667085" FontSize="18" HorizontalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="0" Background="#F8FBFF" CornerRadius="18,0,0,18" Padding="26,26,16,18" BorderBrush="#E6EEF9" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,18">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Border x:Name="PageIconBadge" Width="38" Height="38" CornerRadius="19" Background="#EAF3FF" Margin="0,0,12,0">
                            <TextBlock x:Name="PageIconText" FontFamily="Segoe MDL2 Assets" Text="&#xE81C;" Foreground="#2F7DF6" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="PageTitle" Text="历史" FontSize="26" FontWeight="SemiBold" Foreground="#101828"/>
                            <TextBlock x:Name="PageSubtitle" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button x:Name="ClearButton" Style="{StaticResource HeaderButtonStyle}" Margin="0,0,12,0" Click="ClearButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="15" Margin="0,0,8,0"/>
                                <TextBlock x:Name="ClearButtonText" Text="清空"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource HeaderButtonStyle}" Background="#2F7DF6" Foreground="White" BorderBrush="#2F7DF6" Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="15" Margin="0,0,8,0"/>
                                <TextBlock Text="刷新"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,14,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="CategoryColumn" Width="190"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="42" Background="#FFFFFF" BorderBrush="#C9D8EF" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" Foreground="#7C8BA1" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     TextChanged="SearchBox_TextChanged"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0,7,12,7"
                                     MinHeight="38"
                                     VerticalContentAlignment="Center"
                                     ToolTip="搜索剪切板内容、来源应用、收藏别名或分类"/>
                        </Grid>
                    </Border>

                    <ComboBox x:Name="CategoryFilterBox"
                              Grid.Column="1"
                              Height="42"
                              Margin="0,0,12,0"
                              SelectionChanged="CategoryFilterBox_SelectionChanged"/>

                </Grid>

                <ScrollViewer Grid.Row="2" Padding="0,0,2,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsList" AllowDrop="True" Drop="ItemsList_Drop" SizeChanged="ItemsList_SizeChanged">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="Card"
                                        Tag="{Binding}"
                                        Width="{Binding CardWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Height="132"
                                        Padding="14"
                                        Margin="0,0,12,12"
                                        Background="#FFFFFF"
                                        BorderBrush="#E1E9F5"
                                        BorderThickness="1"
                                        CornerRadius="11"
                                        ToolTip="{Binding ContentText, Mode=OneWay}"
                                        RenderTransformOrigin="0.5,0.5"
                                        PreviewMouseLeftButtonDown="ItemCard_PreviewMouseLeftButtonDown"
                                        MouseMove="ItemCard_MouseMove"
                                        MouseLeftButtonUp="ItemCard_MouseLeftButtonUp"
                                        DragEnter="ItemCard_DragEnter"
                                        DragLeave="ItemCard_DragLeave"
                                        DragOver="ItemCard_DragOver"
                                        Drop="ItemCard_Drop">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#9CADC7" Opacity="0.12" BlurRadius="18" ShadowDepth="4"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Height="3" Background="#2F7DF6" CornerRadius="2" VerticalAlignment="Top" Margin="-14,-14,-14,0"/>

                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Background="#2F7DF6"
                                                CornerRadius="0,10,0,8"
                                                Padding="7,4"
                                                Margin="0,-14,-14,0"
                                                Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE718;" Foreground="White" FontSize="13"/>
                                        </Border>

                                        <Grid Grid.Row="0" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="TypeIconColumn" Width="0"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="TypeIcon" Width="34" Height="34" CornerRadius="9" Background="#EAF3FF" Margin="0,0,10,0" Visibility="Collapsed">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D2;" Foreground="#2F7DF6" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding ShortDisplayTitle, Mode=OneWay}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="#101828"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,24,0"/>
                                                <TextBlock Text="{Binding ShortPreview, Mode=OneWay}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="13"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Grid.Row="1" Style="{StaticResource TagPillStyle}" Margin="0,7,0,0">
                                            <TextBlock Text="{Binding FavoriteMeta, Mode=OneWay}" Foreground="#167A4A" FontSize="12" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        </Border>

                                        <Grid Grid.Row="3" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13"
                                                       TextWrapping="NoWrap"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="&#xE718;"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Tag="{Binding}"
                                                        Click="PinItem_Click"
                                                        Margin="0,0,8,0"
                                                        ToolTip="固定"
                                                        Visibility="{Binding IsFavoritesView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <Button x:Name="FavoriteButton"
                                                        Content="&#xE734;"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Tag="{Binding}"
                                                        Click="FavoriteItem_Click"
                                                        Margin="0,0,8,0"
                                                        ToolTip="收藏"/>
                                                <Button Content="&#xE74D;"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Tag="{Binding}"
                                                        Click="DeleteItem_Click"
                                                        ToolTip="删除"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFavoritesView, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter TargetName="Card" Property="Height" Value="146"/>
                                        <Setter TargetName="TypeIconColumn" Property="Width" Value="44"/>
                                        <Setter TargetName="TypeIcon" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter TargetName="FavoriteButton" Property="Foreground" Value="#F59E0B"/>
                                        <Setter TargetName="FavoriteButton" Property="BorderBrush" Value="#FDE7B2"/>
                                        <Setter TargetName="FavoriteButton" Property="Background" Value="#FFF8E6"/>
                                    </DataTrigger>
                                    <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Card" Property="BorderBrush" Value="#BFD1F7"/>
                                        <Setter TargetName="Card" Property="Background" Value="#FEFFFF"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid x:Name="PaginationBar" Grid.Row="3" Margin="0,10,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource IconButtonStyle}" Content="&#xE76B;" Width="38" Height="38" MinHeight="38"/>
                        <Border Width="38" Height="38" CornerRadius="9" Background="#2F7DF6" Margin="10,0">
                            <TextBlock Text="1" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Button Style="{StaticResource IconButtonStyle}" Content="&#xE76C;" Width="38" Height="38" MinHeight="38"/>
                    </StackPanel>
                    <ComboBox Width="112" Height="38" HorizontalAlignment="Right" SelectedIndex="0">
                        <ComboBoxItem Content="12 条/页"/>
                        <ComboBoxItem Content="24 条/页"/>
                        <ComboBoxItem Content="48 条/页"/>
                    </ComboBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
