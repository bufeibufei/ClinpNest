<Window x:Class="ClipNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNest" Height="760" Width="1280"
        MinHeight="620" MinWidth="980"
        Icon="Assets/clipnest.png"
        WindowStartupLocation="CenterScreen"
        Background="#F4F8FF">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#EEF5FF" Padding="22">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,34">
                        <Border Width="42" Height="42" CornerRadius="10" Background="#2F7DF6" Margin="0,0,12,0">
                            <Image Source="Assets/clipnest.png" Width="24" Height="24"/>
                        </Border>
                        <TextBlock Text="ClipNest" FontSize="23" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="HistoryButton" Content="历史" HorizontalContentAlignment="Left" Margin="0,0,0,10" Click="HistoryButton_Click"/>
                    <Button x:Name="FavoritesButton" Content="收藏" HorizontalContentAlignment="Left" Margin="0,0,0,10" Click="FavoritesButton_Click"/>
                    <Button Content="设置" HorizontalContentAlignment="Left" Click="SettingsButton_Click"/>

                    <Border Height="1" Background="#DDE7F5" Margin="0,28,0,20"/>
                    <TextBlock Text="管理" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <Button x:Name="PauseButton" Click="PauseButton_Click" HorizontalContentAlignment="Left"/>
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Background="#FFFFFF" CornerRadius="10" Padding="16" BorderBrush="#E3EAF5" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="剪切板历史" FontWeight="SemiBold"/>
                        <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,10"/>
                        <Border Height="5" Background="#E5EDF8" CornerRadius="3">
                            <Border Width="120" Background="#2F7DF6" CornerRadius="3" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="28" Background="#FBFDFF" CornerRadius="16" Padding="28" BorderBrush="#E5ECF6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,22">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="PageTitle" Text="历史" FontSize="30" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PageSubtitle" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Content="清空" MinHeight="36" Padding="18,6" Margin="0,0,12,0" Click="ClearButton_Click"/>
                        <Button Content="刷新" MinHeight="36" Padding="18,6" Background="#2F7DF6" Foreground="White" BorderBrush="#2F7DF6" Click="RefreshButton_Click"/>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" MinHeight="44" Margin="0,0,12,0"
                             ToolTip="搜索内容、来源应用、收藏别名或分类"/>
                    <ComboBox x:Name="CategoryFilterBox" Grid.Column="1" MinHeight="44" SelectionChanged="CategoryFilterBox_SelectionChanged"/>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsList" AllowDrop="True" Drop="ItemsList_Drop">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="Card" Tag="{Binding}" Padding="16" Margin="0,0,18,18" Background="#FFFFFF"
                                        BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"
                                        Width="360" Height="158"
                                        ToolTip="{Binding ContentText, Mode=OneWay}"
                                        RenderTransformOrigin="0.5,0.5"
                                        PreviewMouseLeftButtonDown="ItemCard_PreviewMouseLeftButtonDown"
                                        MouseMove="ItemCard_MouseMove"
                                        MouseLeftButtonUp="ItemCard_MouseLeftButtonUp"
                                        DragEnter="ItemCard_DragEnter"
                                        DragLeave="ItemCard_DragLeave"
                                        DragOver="ItemCard_DragOver"
                                        Drop="ItemCard_Drop">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Border Height="3" Background="#2F7DF6" CornerRadius="2" VerticalAlignment="Top" Margin="-16,-16,-16,0"/>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Background="#2563EB" CornerRadius="7" Padding="7,2"
                                                Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="固定" Foreground="White" FontSize="11"/>
                                        </Border>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding ShortDisplayTitle, Mode=OneWay}" FontWeight="SemiBold" FontSize="15"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,0,58,0"/>
                                            <TextBlock Grid.Row="1" Text="{Binding ShortPreview, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,7,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="2" Text="{Binding FavoriteMeta, Mode=OneWay}" Foreground="#167A4A"
                                                       Margin="0,12,0,0" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="4" Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="NoWrap"/>
                                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="固定" MinHeight="28" Padding="10,2" Tag="{Binding}" Click="PinItem_Click" Margin="0,0,8,0"
                                                        Visibility="{Binding IsFavoritesView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <Button Content="收藏" MinHeight="28" Padding="10,2" Tag="{Binding}" Click="FavoriteItem_Click" Margin="0,0,8,0"/>
                                                <Button Content="删除" MinHeight="28" Padding="10,2" Tag="{Binding}" Click="DeleteItem_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Card" Property="BorderBrush" Value="#B8C7F8"/>
                                        <Setter TargetName="Card" Property="Background" Value="#FAFCFF"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
