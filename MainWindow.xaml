<Window x:Class="ClipNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNest" Height="680" Width="1120"
        MinHeight="540" MinWidth="820"
        Icon="Assets/clipnest.png"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F0F1F5" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="ClipNest" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,24"/>
                    <Button x:Name="HistoryButton" Content="历史" HorizontalContentAlignment="Left" Margin="0,0,0,8" Click="HistoryButton_Click"/>
                    <Button x:Name="FavoritesButton" Content="收藏" HorizontalContentAlignment="Left" Margin="0,0,0,8" Click="FavoritesButton_Click"/>
                    <Button Content="设置" HorizontalContentAlignment="Left" Click="SettingsButton_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button x:Name="PauseButton" Click="PauseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="PageTitle" Text="历史" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock x:Name="PageSubtitle" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Content="清空" MinHeight="28" Padding="12,3" Margin="0,0,8,0" Click="ClearButton_Click"/>
                    <Button Content="刷新" MinHeight="28" Padding="12,3" Click="RefreshButton_Click"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Margin="0,0,0,10"
                             ToolTip="搜索内容、来源应用、收藏别名或 tag"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ItemsList" AllowDrop="True" Drop="ItemsList_Drop">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="Card" Tag="{Binding}" Padding="10" Margin="0,0,10,10" Background="#FFFFFF"
                                            BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8"
                                            Width="230" Height="126"
                                            ToolTip="{Binding ContentText, Mode=OneWay}"
                                            RenderTransformOrigin="0.5,0.5"
                                            PreviewMouseLeftButtonDown="ItemCard_PreviewMouseLeftButtonDown"
                                            MouseMove="ItemCard_MouseMove"
                                            MouseLeftButtonUp="ItemCard_MouseLeftButtonUp"
                                            DragEnter="ItemCard_DragEnter"
                                            DragLeave="ItemCard_DragLeave"
                                            DragOver="ItemCard_DragOver"
                                            Drop="ItemCard_Drop">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Grid>
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Background="#2563EB" CornerRadius="7" Padding="6,1"
                                                    Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="固定" Foreground="White" FontSize="11"/>
                                            </Border>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Margin="0,0,44,0">
                                                    <TextBlock Text="{Binding ShortDisplayTitle, Mode=OneWay}" FontWeight="SemiBold"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ShortPreview, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,5,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,7,0,0" FontSize="12"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding FavoriteMeta, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:g}}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                    <Button Content="固定" MinHeight="26" Padding="9,2" Tag="{Binding}" Click="PinItem_Click" Margin="0,0,6,0"
                                                            Visibility="{Binding IsFavoritesView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <Button Content="收藏" MinHeight="26" Padding="9,2" Tag="{Binding}" Click="FavoriteItem_Click" Margin="0,0,6,0"/>
                                                    <Button Content="删除" MinHeight="26" Padding="9,2" Tag="{Binding}" Click="DeleteItem_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Card" Property="BorderBrush" Value="#B8C7F8"/>
                                            <Setter TargetName="Card" Property="Background" Value="#FAFCFF"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
