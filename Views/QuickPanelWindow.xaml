<Window x:Class="ClipNest.Views.QuickPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNest Quick Panel"
        Width="800" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border Background="#FDFDFE" CornerRadius="12" Padding="14"
            BorderBrush="#DADDE5" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="8"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" FontSize="16" MinHeight="42"
                     ToolTip="搜索内容、收藏别名或分类"
                     TextChanged="SearchBox_TextChanged"
                     KeyDown="SearchBox_KeyDown"/>

            <TextBlock Grid.Row="1" Text="收藏" FontWeight="SemiBold" Margin="2,14,0,8"/>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="FavoritesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Tag="{Binding}" Width="246" Height="118" Padding="10" Margin="0,0,10,10"
                                    Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                    ToolTip="{Binding ContentText, Mode=OneWay}"
                                    MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                <Grid>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="#2563EB" CornerRadius="7" Padding="6,1"
                                            Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="固定" Foreground="White" FontSize="11"/>
                                    </Border>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding ShortDisplayTitle, Mode=OneWay}" FontWeight="SemiBold"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,0,44,0"/>
                                        <TextBlock Grid.Row="1" Text="{Binding ShortPreview, Mode=OneWay}" Foreground="#696B72"
                                                   Margin="0,5,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="2" Text="{Binding FavoriteMeta, Mode=OneWay}" Foreground="#696B72"
                                                   FontSize="12" Margin="0,7,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="4" Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                   Foreground="#696B72" FontSize="12" TextWrapping="NoWrap"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="3" Text="历史" FontWeight="SemiBold" Margin="2,12,0,8"/>
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Tag="{Binding}" Width="246" Height="98" Padding="10" Margin="0,0,10,10"
                                    Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                    ToolTip="{Binding ContentText, Mode=OneWay}"
                                    MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding ShortPreview, Mode=OneWay}"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="1" Text="{Binding SourceApp, Mode=OneWay}" Foreground="#696B72"
                                               Margin="0,8,0,0" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="3" Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                               Foreground="#696B72" FontSize="12" TextWrapping="NoWrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="5" Text="Enter 粘贴第一项 · Esc 关闭"
                       Foreground="#696B72" HorizontalAlignment="Right" Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
