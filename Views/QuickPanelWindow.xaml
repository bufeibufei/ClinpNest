<Window x:Class="ClipNest.Views.QuickPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipNest 搜索"
        Width="860" Height="680"
        MinWidth="620" MinHeight="460"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#F4F8FF"
        KeyDown="Window_KeyDown">
    <Border Background="#FBFDFF" CornerRadius="12" Padding="18" BorderBrush="#E5ECF6" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" FontSize="16" MinHeight="42" Margin="0,0,12,0"
                         ToolTip="搜索内容、收藏别名或分类"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"/>
                <ComboBox x:Name="CategoryFilterBox" Grid.Column="1" MinHeight="42" SelectionChanged="CategoryFilterBox_SelectionChanged"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="收藏" FontWeight="SemiBold" Margin="2,16,0,8"/>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="FavoritesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Tag="{Binding}" Width="250" Height="124" Padding="12" Margin="0,0,12,12"
                                    Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"
                                    ToolTip="{Binding ContentText, Mode=OneWay}"
                                    MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                <Grid>
                                    <Border Height="3" Background="#2F7DF6" CornerRadius="2" VerticalAlignment="Top" Margin="-12,-12,-12,0"/>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="#2563EB" CornerRadius="7" Padding="6,1"
                                            Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="固定" Foreground="White" FontSize="11"/>
                                    </Border>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding ShortDisplayTitle, Mode=OneWay}" FontWeight="SemiBold"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,0,48,0"/>
                                        <TextBlock Grid.Row="1" Text="{Binding ShortPreview, Mode=OneWay}" Foreground="#696B72"
                                                   Margin="0,5,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="2" Text="{Binding FavoriteMeta, Mode=OneWay}" Foreground="#167A4A"
                                                   FontSize="12" Margin="0,7,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="4" Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                   Foreground="#696B72" FontSize="12" TextWrapping="NoWrap"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="3" Text="历史" FontWeight="SemiBold" Margin="2,12,0,8"/>
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Tag="{Binding}" Width="250" Height="104" Padding="12" Margin="0,0,12,12"
                                    Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"
                                    ToolTip="{Binding ContentText, Mode=OneWay}"
                                    MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding ShortPreview, Mode=OneWay}"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="1" Text="{Binding SourceApp, Mode=OneWay}" Foreground="#696B72"
                                               Margin="0,8,0,0" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="3" Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                               Foreground="#696B72" FontSize="12" TextWrapping="NoWrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="5" Text="Enter 粘贴第一项 · Esc 关闭"
                       Foreground="#696B72" HorizontalAlignment="Right" Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
