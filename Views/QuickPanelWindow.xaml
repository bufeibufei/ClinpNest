<Window x:Class="ClipNest.Views.QuickPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ClipNest.Controls"
        xmlns:services="clr-namespace:ClipNest.Services"
        Title="ClipNest 搜索"
        Width="1260" Height="700"
        MinWidth="900" MinHeight="540"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#F4F8FF"
        Icon="../Assets/clipnest.png"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <services:IdEqualsConverter x:Key="IdEqualsConverter"/>

        <Style x:Key="QuickIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Foreground" Value="#526174"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DFE7F2"/>
        </Style>
    </Window.Resources>

    <Border Background="#FBFDFF" CornerRadius="12" Padding="24" BorderBrush="#D6E2F2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <Border Height="52" Background="#FFFFFF" BorderBrush="#2F7DF6" BorderThickness="1" CornerRadius="9" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" Foreground="#496A9A" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 FontSize="18"
                                 MinHeight="48"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0,8,14,8"
                                 ToolTip="搜索剪切板内容、来源应用或标签"
                                 TextChanged="SearchBox_TextChanged"
                                 KeyDown="SearchBox_KeyDown"/>
                    </Grid>
                </Border>

                <ComboBox x:Name="CategoryFilterBox" Grid.Column="1" Height="52" FontSize="16" SelectionChanged="CategoryFilterBox_SelectionChanged"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="收藏" FontSize="16" FontWeight="SemiBold" Foreground="#101828" Margin="2,22,0,12"/>
            <ScrollViewer Grid.Row="2" Padding="0,0,2,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="FavoritesList" SizeChanged="QuickList_SizeChanged">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="FavoriteCard" Tag="{Binding}" Width="{Binding FavoriteCardWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="146" Padding="16" Margin="0,0,12,12"
                                    Background="#FFFFFF" BorderBrush="#DFE7F2" BorderThickness="1" CornerRadius="9"
                                    ToolTip="{Binding ContentText, Mode=OneWay}"
                                    PreviewMouseLeftButtonDown="ItemCard_PreviewMouseLeftButtonDown"
                                    MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                <Border.Effect>
                                    <DropShadowEffect Color="#9CADC7" Opacity="0.12" BlurRadius="16" ShadowDepth="3"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Height="3" Background="#2F7DF6" CornerRadius="2" VerticalAlignment="Top" Margin="-16,-16,-16,0"/>
                                    <controls:HighlightedTextBlock Grid.Row="0" RawText="{Binding ShortDisplayTitle, Mode=OneWay}" Query="{Binding SearchQuery, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold" FontSize="15"
                                                                   Foreground="#101828" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,12,0,0"/>
                                    <controls:HighlightedTextBlock Grid.Row="1" RawText="{Binding ShortPreview, Mode=OneWay}" Query="{Binding SearchQuery, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Margin="0,7,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Row="2" Background="#DDF3EE" CornerRadius="7" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                        <controls:HighlightedTextBlock RawText="{Binding FavoriteMeta, Mode=OneWay}" Query="{Binding SearchQuery, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#087C66" FontSize="12" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FavoriteDisplayTime, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource QuickIconButtonStyle}" Content="&#xE734;" Foreground="#F59E0B" Tag="{Binding}" Click="FavoriteItem_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource IdEqualsConverter}">
                                            <Binding Path="Id"/>
                                            <Binding Path="SelectedItemId" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter TargetName="FavoriteCard" Property="BorderBrush" Value="#2F7DF6"/>
                                    <Setter TargetName="FavoriteCard" Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="3" Text="历史" FontSize="16" FontWeight="SemiBold" Foreground="#101828" Margin="2,18,0,12"/>
            <ScrollViewer Grid.Row="4" Padding="0,0,2,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="HistoryList" SizeChanged="QuickList_SizeChanged">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="HistoryCard" Tag="{Binding}" Width="{Binding HistoryCardWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="112" Padding="16" Margin="0,0,12,12"
                                    Background="#FFFFFF" BorderBrush="#DFE7F2" BorderThickness="1" CornerRadius="9"
                                    ToolTip="{Binding ContentText, Mode=OneWay}"
                                    PreviewMouseLeftButtonDown="ItemCard_PreviewMouseLeftButtonDown"
                                    MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <controls:HighlightedTextBlock Grid.Row="0" RawText="{Binding ShortPreview, Mode=OneWay}" Query="{Binding SearchQuery, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold"
                                                                   Foreground="#101828" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Row="1" Background="#DDF3EE" CornerRadius="7" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                        <controls:HighlightedTextBlock RawText="{Binding SourceApp, Mode=OneWay}" Query="{Binding SearchQuery, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#087C66"
                                                                       FontSize="12" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding UpdatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource QuickIconButtonStyle}" Content="&#xE734;" Tag="{Binding}" Click="FavoriteItem_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource IdEqualsConverter}">
                                            <Binding Path="Id"/>
                                            <Binding Path="SelectedItemId" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter TargetName="HistoryCard" Property="BorderBrush" Value="#2F7DF6"/>
                                    <Setter TargetName="HistoryCard" Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="5" Text="Enter 粘贴第一项 · Esc 关闭"
                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
