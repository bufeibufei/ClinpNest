<Window x:Class="ClipNest.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="640"
        Width="560"
        MinHeight="620"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#EEF4FF">
    <Border Background="#FBFDFF" BorderBrush="#C9D8EF" BorderThickness="1" CornerRadius="16" Margin="12">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="设置" FontSize="26" FontWeight="SemiBold" Foreground="#101828"/>
                <TextBlock Text="调整快捷键、历史容量和收藏分类。"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,22"/>
            </StackPanel>

            <Border Grid.Row="1" Height="1" Background="#E4ECF7" Margin="0,0,0,18"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="快捷键" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBox x:Name="HotkeyBox" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                    <TextBlock x:Name="HintText" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,22"/>

                    <TextBlock Text="历史条目存储上限" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="HistoryLimitSlider"
                                Minimum="20"
                                Maximum="500"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                ValueChanged="HistoryLimitSlider_ValueChanged"/>
                        <TextBox x:Name="HistoryLimitBox"
                                 Grid.Column="1"
                                 Margin="12,0,0,0"
                                 TextChanged="HistoryLimitBox_TextChanged"/>
                    </Grid>
                    <TextBlock Text="默认 100。收藏条目不会因为达到历史上限而被自动删除。"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,26"/>

                    <TextBlock Text="启动" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <CheckBox x:Name="StartupCheckBox"
                              Content="开机后自动启动 ClipNest"
                              MinHeight="34"
                              Margin="0,0,0,24"/>

                    <TextBlock Text="收藏分类" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CategoryNameBox"
                                 MinHeight="40"
                                 ToolTip="输入新分类名称，或选择已有分类后修改名称"/>
                        <Button Grid.Column="1" Content="保存分类" Margin="10,0,0,0" Click="SaveCategoryButton_Click"/>
                        <Button Grid.Column="2" Content="删除" Margin="10,0,0,0" Click="DeleteCategoryButton_Click"/>
                    </Grid>
                    <TextBlock Text="选择分类后可重命名；删除分类会保留收藏条目，并清空这些条目的分类。"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,10"/>
                    <ListBox x:Name="CategoryList"
                             MinHeight="130"
                             BorderBrush="#C9D8EF"
                             SelectionChanged="CategoryList_SelectionChanged"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="3" BorderBrush="#DDE7F3" BorderThickness="0,1,0,0" Padding="0,18,0,0" Margin="0,18,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Width="96" Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Content="保存" Width="108" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
