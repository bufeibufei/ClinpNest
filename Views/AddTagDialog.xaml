<Window x:Class="ClipNest.Views.AddTagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加分类"
        Height="240"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">
    <Border Background="{StaticResource WindowBackgroundBrush}" Padding="22">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="取消" Margin="0,0,8,0" Click="CancelButton_Click"/>
                <Button Content="添加" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Click="AddButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="添加分类" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="输入一个新的分类名称。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,18"/>
                <TextBlock Text="分类名称" Margin="0,0,0,8"/>
                <TextBox x:Name="TagNameBox"
                         Height="40"
                         Width="336"
                         HorizontalAlignment="Left"
                         Background="#FFFFFF"
                         Foreground="#202124"
                         BorderBrush="#2563EB"
                         BorderThickness="1"
                         Padding="12,8"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
