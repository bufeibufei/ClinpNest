<Window x:Class="ClipNest.Views.AddTagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加分类" Height="190" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="添加分类 tag" FontSize="20" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="输入一个新的分类名称。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,14"/>
        <TextBox Grid.Row="2" x:Name="TagNameBox"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="添加" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
