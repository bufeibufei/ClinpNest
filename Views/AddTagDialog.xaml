<Window x:Class="ClipNest.Views.AddTagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加分类"
        Height="260"
        Width="420"
        MinHeight="260"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource WindowBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="添加分类" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="输入一个新的分类名称。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,18"/>
        <TextBlock Grid.Row="2" Text="分类名称" Margin="0,0,0,8"/>
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="7" Height="42">
            <TextBox x:Name="TagNameBox"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="#202124"
                     Padding="12,8"
                     VerticalContentAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="添加" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
