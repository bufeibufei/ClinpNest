<Window x:Class="ClipNest.Views.FavoriteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="收藏条目" Height="360" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="收藏条目" FontSize="24" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="为收藏内容设置一个容易搜索的别名和分类 tag。"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,20"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="别名" Margin="0,0,0,6"/>
            <TextBox x:Name="AliasBox"/>
            <TextBlock Text="分类 tag" Margin="0,16,0,6"/>
            <TextBox x:Name="TagBox"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#F7F7FA" CornerRadius="8" Padding="12" Margin="0,18,0,18">
            <TextBlock x:Name="PreviewText" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="70"/>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RemoveButton" Content="取消收藏" Margin="0,0,8,0" Click="RemoveButton_Click"/>
            <Button Content="取消" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="保存" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
