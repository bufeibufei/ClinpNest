<Window x:Class="ClipNest.Views.FavoriteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="收藏条目"
        Height="650"
        Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF4FF">
    <Border Background="#FBFDFF" BorderBrush="#C9D8EF" BorderThickness="1" CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="78"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#DDE7F3" BorderThickness="0,0,0,1" Padding="30,0">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Width="38"
                            Height="38"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="CancelButton_Click"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="7" Background="#2F7DF6" Margin="0,0,14,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" Foreground="White" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="收藏条目" FontSize="20" FontWeight="SemiBold" Foreground="#101828" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="36,32,36,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="收藏条目" FontSize="30" FontWeight="SemiBold" Foreground="#101828"/>
                <TextBlock Grid.Row="1" Text="设置别名，并从下拉框选择分类。" Foreground="{StaticResource TextSecondaryBrush}" FontSize="15" Margin="0,10,0,28"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="别名" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBox x:Name="AliasBox" Height="56" FontSize="16" Padding="18,10" BorderBrush="#B9C9E5"/>

                    <TextBlock Text="分类" FontSize="18" FontWeight="SemiBold" Margin="0,28,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="92"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="TagBox" IsEditable="False" Height="52" FontSize="16" Padding="14,8"/>
                        <Button Grid.Column="1" Content="添加" Height="52" Margin="14,0,0,0" FontSize="16" Click="AddTagButton_Click"/>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="3" Background="#F6F9FE" BorderBrush="#DDE7F3" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,32,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="42" Height="42" CornerRadius="21" Background="#EAF3FF">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" Foreground="#2F7DF6" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="原始内容预览" FontSize="16" FontWeight="SemiBold" Foreground="#101828"/>
                            <TextBlock x:Name="PreviewText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="15" Margin="0,8,0,0"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PreviewTimeText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#DDF3EE" CornerRadius="10" Padding="12,5" VerticalAlignment="Bottom">
                            <TextBlock x:Name="PreviewSourceText" Foreground="#087C66" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#DDE7F3" BorderThickness="0,1,0,0" Padding="0,0,36,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="RemoveButton" Content="取消收藏" Width="118" Height="44" Margin="0,0,12,0" Click="RemoveButton_Click"/>
                    <Button Content="取消" Width="104" Height="44" Margin="0,0,12,0" FontSize="16" Click="CancelButton_Click"/>
                    <Button Content="保存" Width="120" Height="44" FontSize="16" Background="#2F7DF6" Foreground="White" BorderBrush="#2F7DF6" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
